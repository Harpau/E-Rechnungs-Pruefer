# Lokaler HTTP-Server
HOST=127.0.0.1
PORT=8080
MAX_UPLOAD_BYTES=26214400
MAX_TECHNICAL_ROWS=100000

# Optionale offizielle KoSIT-Prüfung
# Der Installer scripts/install_kosit.py erzeugt normalerweise .env.kosit automatisch.
KOSIT_ENABLED=true
KOSIT_JAVA_BIN=java
KOSIT_VALIDATOR_JAR=vendor/kosit/validator/validator-1.6.2-standalone.jar
KOSIT_SCENARIOS=vendor/kosit/xrechnung/scenarios.xml
KOSIT_REPOSITORIES=vendor/kosit/xrechnung
KOSIT_TIMEOUT_SECONDS=60
